# RNA stack environment template (do not commit real secrets)
NODE_ENV=production
RNA_API_PORT=3005

RNA_POSTGRES_USER=rna_admin
RNA_POSTGRES_PASSWORD=change_me
RNA_POSTGRES_DB=rna_db

RNA_MINIO_ROOT_USER=rna_admin
RNA_MINIO_ROOT_PASSWORD=change_me

RNA_DATABASE_URL=postgresql://rna_admin:change_me@postgres:5432/rna_db
RNA_REDIS_URL=redis://redis:6379
RNA_NEO4J_URI=bolt://neo4j:7687
RNA_NEO4J_USER=neo4j
RNA_NEO4J_PASSWORD=
RNA_QDRANT_URL=http://qdrant:6333
RNA_MINIO_ENDPOINT=minio
RNA_MINIO_PORT=9000
RNA_MINIO_ACCESS_KEY=rna_admin
RNA_MINIO_SECRET_KEY=change_me

# Required for embeddings
OPENAI_API_KEY=
